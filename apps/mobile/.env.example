# Copy to .env.local and set for your machine. Loaded automatically by Expo.
# EXPO_PUBLIC_ vars are inlined into the JS bundle at build time, so restart the
# bundler (npm start -c) after changing them.

# Token server endpoint — must be reachable from the device/emulator:
#   USB device (recommended): http://localhost:3001/getToken — run
#     `adb reverse tcp:3001 tcp:3001` once per USB session. Tunnels over USB, so
#     it ignores the Wi-Fi firewall and survives DHCP IP changes (same mechanism
#     Metro's 8081 uses). Re-run after replugging the device or restarting adb.
#   Physical device over Wi-Fi: your dev machine's LAN IP (same Wi-Fi), e.g.
#     http://192.168.1.66:3001/getToken — requires the firewall to allow inbound
#     TCP 3001 (Windows blocks this by default on "Public" networks).
#   Android emulator: http://10.0.2.2:3001/getToken
#   iOS simulator:    http://localhost:3001/getToken
EXPO_PUBLIC_TOKEN_ENDPOINT=http://localhost:3001/getToken
